# ----------------------------------------------------------------------------
# Vercel OAuth integration (for one-click "Connect Vercel")
#
# Create an integration at https://vercel.com/dashboard/integrations/create
# - Redirect URL must be: http://localhost:3000/api/auth/callback
# - Copy the Client ID and Client Secret here.
# ----------------------------------------------------------------------------
VERCEL_CLIENT_ID=
VERCEL_CLIENT_SECRET=

# Base URL of this app (used to build the OAuth redirect URI).
APP_URL=http://localhost:3000

# Secret used to sign the session cookie. Use any long random string.
SESSION_SECRET=change-me-to-a-long-random-string
